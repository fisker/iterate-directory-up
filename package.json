{
  "name": "iterate-directory-up",
  "version": "1.5.1",
  "description": "Iterate directory up.",
  "homepage": "https://github.com/fisker/iterate-directory-up#readme",
  "bugs": {
    "url": "https://github.com/fisker/iterate-directory-up/issues"
  },
  "repository": "fisker/iterate-directory-up",
  "funding": "https://github.com/fisker/iterate-directory-up?sponsor=1",
  "license": "MIT",
  "author": {
    "name": "fisker Cheung",
    "email": "lionkay@gmail.com",
    "url": "https://www.fiskercheung.com/"
  },
  "sideEffects": false,
  "type": "module",
  "exports": "./index.js",
  "files": [
    "index.js",
    "index.d.ts",
    "index.d.ts.map"
  ],
  "scripts": {
    "benchmark": "node benchmark/benchmark.js",
    "build": "run-p clean \"build:*\"",
    "build:types": "tsc --emitDeclarationOnly --noEmit false",
    "clean": "run-p \"clean:*\"",
    "clean:dist": "del-cli dist",
    "debug": "node --watch example.js",
    "dist": "run-p \"dist:*\"",
    "dist:npm": "release-it",
    "fix": "run-p --continue-on-error \"fix:*\"",
    "fix:eslint": "yarn lint:eslint --fix",
    "fix:markdown": "yarn lint:markdown --fix",
    "fix:package-json": "sort-package-json \"package.json\" \"packages/*/package.json\"",
    "fix:prettier": "prettier . --write",
    "lint": "run-p --continue-on-error \"lint:*\"",
    "lint:eslint": "eslint .",
    "lint:markdown": "markdownlint-cli2",
    "lint:package-json": "yarn run fix:package-json --check",
    "lint:prettier": "prettier . --check",
    "release": "run-s fix build test dist",
    "test": "run-p \"test:*\"",
    "test:js": "node --test test.js",
    "test:types": "yarn build && tsd",
    "test-coverage": "c8 yarn test"
  },
  "c8": {
    "include": [
      "index.js"
    ],
    "reporter": [
      "lcov",
      "text"
    ]
  },
  "dependencies": {
    "url-or-path": "^2.6.1"
  },
  "devDependencies": {
    "@fisker/eslint-config": "15.4.0",
    "@fisker/lint-staged-config": "3.4.0",
    "@fisker/markdownlint-cli2-config": "0.1.0",
    "@fisker/prettier-config": "5.3.0",
    "@fisker/release-it-config": "6.0.2",
    "@types/node": "25.9.1",
    "c8": "11.0.0",
    "del-cli": "7.0.0",
    "eslint": "9.26.0",
    "markdownlint-cli2": "0.22.1",
    "npm-run-all2": "9.0.1",
    "prettier": "3.8.3",
    "release-it": "20.0.1",
    "sort-package-json": "3.6.1",
    "tinybench": "6.0.2",
    "tsd": "0.33.0",
    "typescript": "6.0.3"
  },
  "packageManager": "yarn@4.9.1",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
